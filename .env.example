# OwnNet Vault Environment Variables
# Copy this file to .env and fill in your values

# Pinata IPFS Configuration (Required for production)
# Get your JWT from: https://app.pinata.cloud/keys
VITE_PINATA_JWT=your_pinata_jwt_token_here

# Optional: Custom Pinata Gateway (defaults to gateway.pinata.cloud)
VITE_PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs/

# Smart Contract Address (deploy to Sepolia testnet)
VITE_CONTRACT_ADDRESS=0xYourDeployedContractAddress

# Infura Project ID (optional, for direct IPFS node connection)
# Not needed if using Pinata
VITE_INFURA_PROJECT_ID=your_infura_project_id
VITE_INFURA_PROJECT_SECRET=your_infura_project_secret